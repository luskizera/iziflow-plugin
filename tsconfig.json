{
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./src",
    "module": "esnext",
    "target": "ES6",
    "lib": ["es6", "DOM"],
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["@figma/plugin-typings"],
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
