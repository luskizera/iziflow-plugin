{
  "compilerOptions": {
    "outDir": "./build",
    "module": "CommonJS",
    "target": "es2015",
    "lib": ["es2015"], // Remove "dom" para evitar conflitos com @figma/plugin-typings
    "strict": true,
    "moduleResolution": "node",
    "sourceMap": false,
    "removeComments": true,
    "esModuleInterop": true,
    "types": ["@figma/plugin-typings"]
  },
  "include": ["src/**/*"], // Inclui todos os arquivos .ts em src/
  "exclude": ["node_modules", "**/*.spec.ts", "src/ui/**/*"] // Exclui os arquivos da UI (HTML, CSS, JS)
}