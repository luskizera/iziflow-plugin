{
  "compilerOptions": {
    "outDir": "./build",
    "module": "CommonJS",
    "target": "es2015",
    "lib": ["es2015", "dom"],
    "strict": true,
    "moduleResolution": "node",
    "sourceMap": false,
    "removeComments": true,
    "esModuleInterop": true,
    "types": ["@figma/plugin-typings"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}