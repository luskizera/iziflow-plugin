{
  "compilerOptions": {
    "outFile": "./build/code.js",    // Um único arquivo compilado
    "module": "none",                // Não usa módulos
    "target": "es2017",
    "lib": ["es2017"],
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["@figma/plugin-typings"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
